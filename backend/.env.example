# ------------------------------------------------------------------------------
# PEGASUS SALES SYSTEM - CONFIGURACIÓN DEL BACKEND
# Copia este archivo como '.env' en este mismo directorio y completa los valores.
# ------------------------------------------------------------------------------

# Configuración General del Proyecto
PROJECT_NAME="Pegasus SalesSystem API"
ENVIRONMENT=development
PORT=8000

# Base de Datos MongoDB (Local o Atlas)
# Ejemplo local: mongodb://localhost:27017
# Ejemplo Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=sales_system_dev

# Seguridad y Autenticación
# Puedes generar una clave segura con el comando: openssl rand -hex 32
JWT_SECRET_KEY=supersecretkey_change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Orígenes Permitidos para CORS (separados por comas)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Inteligencia Artificial (Google Gemini)
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# Integración con Cloudinary (Almacenamiento de imágenes de productos)
CLOUDINARY_CLOUD_NAME=tu_cloudinary_cloud_name
CLOUDINARY_API_KEY=tu_cloudinary_api_key
CLOUDINARY_API_SECRET=tu_cloudinary_api_secret
